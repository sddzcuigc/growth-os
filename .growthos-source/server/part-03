          label: database.label
        }
      });
      return;
    }

    if (request.method === "GET" && url.pathname === "/api/ai/modules") return await handleListAiModules(request, response);
    if (request.method === "GET" && /^\/api\/ai\/modules\/[a-z0-9-]+$/.test(url.pathname)) return await handleGetAiModule(request, response, url);
    if (request.method === "POST" && url.pathname === "/api/ai/test") return await handleAiModuleTest(request, response);

    if (request.method === "GET" && url.pathname === "/api/context/news") {
      await handleNewsContext(url, response);
      return;
    }

    if (request.method === "POST" && url.pathname === "/api/coach") {
      await handleCoach(request, response);
      return;
    }

    if (request.method === "POST" && url.pathname === "/api/plan") {
      await handlePlan(request, response);
      return;
    }

    if (request.method !== "GET") {
      sendJson(response, 405, { error: "Method not allowed" });
      return;
    }

    const pathname = url.pathname === "/" ? "/index.html" : url.pathname;
    const extension = extname(pathname);
    const isPublicFile = pathname === "/index.html"
      || pathname === "/app.js"
      || extension === ".css"
      || (pathname.startsWith("/assets/") && [".png", ".jpg", ".jpeg", ".webp", ".svg"].includes(extension));
    if (!isPublicFile) {
      sendJson(response, 404, { error: "Not found" });
      return;
    }
    const filePath = safeJoin(root, pathname);
    if (!filePath) {
      sendJson(response, 403, { error: "Forbidden" });
      return;
    }
    const content = await readFile(filePath);
    response.writeHead(200, {
      "content-type": mimeTypes[extname(filePath)] || "application/octet-stream"
    });
    response.end(content);
  } catch (error) {
    if (error.code === "ENOENT") {
      sendJson(response, 404, { error: "Not found" });
      return;
    }
    console.error(error);
    sendJson(response, 500, { error: "Internal server error" });
  }
}

